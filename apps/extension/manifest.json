{
  "manifest_version": 3,
  "name": "Job App Assistant",
  "version": "0.1.0",
  "description": "Auto-fill job applications and track your application status",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://myworkdayjobs.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.icims.com/*",
    "https://*.successfactors.com/*",
    "https://jobs.sap.com/*",
    "https://jobs.smartrecruiters.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.bamboohr.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.myworkdayjobs.com/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.icims.com/*",
        "https://*.successfactors.com/*",
        "https://jobs.sap.com/*",
        "https://jobs.smartrecruiters.com/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.bamboohr.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
