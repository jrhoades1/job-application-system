# ─────────────────────────────────────────────────────────────────────────────
# Clerk — Authentication
# https://dashboard.clerk.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Secret key (server-only — never expose to the browser)
CLERK_SECRET_KEY=sk_test_...

# Webhook secret — generated in Clerk Dashboard → Webhooks
# Used to verify that incoming webhook events are from Clerk
CLERK_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — Database
# https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Project URL (also exposed via NEXT_PUBLIC_SUPABASE_URL if needed on client)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — full DB access, server-only
# Never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic — Claude AI
# https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth — Gmail integration
# https://console.cloud.google.com → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Must exactly match the Authorized Redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ─────────────────────────────────────────────────────────────────────────────
# Cron — Nightly Pipeline ("Jobs Come to You")
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret used to authenticate calls to /api/cron/nightly-pipeline.
# Vercel injects this automatically as a Bearer token when running cron jobs.
# For local testing, pass it manually: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# ─────────────────────────────────────────────────────────────────────────────
# Resend — Morning digest emails  (optional)
# https://resend.com → API Keys
# If not set, digest emails are skipped but in-app digests still work.
# ─────────────────────────────────────────────────────────────────────────────

# Resend API key — used to send morning digest emails to users
RESEND_API_KEY=re_...

# From address for digest emails — must be a verified domain in Resend
# Example: "digest@yourdomain.com"
RESEND_FROM_EMAIL=digest@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# App URL — used by the nightly pipeline to build links in emails
# Set this to your production URL on Vercel.
# Vercel also exposes VERCEL_URL automatically (no https://).
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Adzuna — Job search API  (optional, supplements Jobicy which is always free)
# https://developer.adzuna.com → Create App → copy app_id + app_key
# If not set, only Jobicy results are fetched during the nightly pipeline.
# ─────────────────────────────────────────────────────────────────────────────

ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ─────────────────────────────────────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────────────────────────────────────

# Clerk user ID of the admin user (for /api/admin/* endpoints)
ADMIN_USER_ID=user_...

# ─────────────────────────────────────────────────────────────────────────────
# E2E Testing (Playwright) — only needed for running e2e tests
# ─────────────────────────────────────────────────────────────────────────────

# Clerk testing credentials — must match an existing Clerk user in your app
E2E_CLERK_USER_USERNAME=test@example.com
E2E_CLERK_USER_PASSWORD=your-test-password
